{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "read_file",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PostToolUse hook fired for read_file with $ARGUMENTS'",
            "shell": "bash"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "execute_command",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PreToolUse hook: about to run command!' >&2",
            "if": "execute_command(git *)"
          }
        ]
      }
    ]
  }
}
